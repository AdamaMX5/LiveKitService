# LiveKit Konfiguration
# Kopieren nach .env und Werte anpassen

LIVEKIT_KEYS="meinkey:meingeheimespasswort"
# Format: "api_key:api_secret"
# Mehrere Keys möglich: "key1:secret1,key2:secret2"

# Diese Werte auch in den PresenceService .env eintragen:
# LIVEKIT_URL=wss://livekit.freischule.info
# LIVEKIT_KEY=meinkey
# LIVEKIT_SECRET=meingeheimespasswort
